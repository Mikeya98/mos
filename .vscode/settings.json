{
    "editor.rulers": [80, 100],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.associations": {
        "*.h": "c",
        "*.c": "c",
        "*.S": "arm",
        "*.lds": "linkerscript"
    },
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/include"
    ],
    "C_Cpp.default.defines": [
        "MOS_ARCH_ARM=1",
        "MOS_BOARD_ZYNQ7045=1"
    ]
}
